{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Build report artifact",
  "description": "Output of /build phase: summary of coordinated build execution.",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "outputs"],
  "properties": {
    "trace_id": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "outputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "description": "File paths modified or created during build."
    },
    "covers_requirement_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["group_id", "status"],
        "properties": {
          "group_id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "fail", "skip"] },
          "tasks_completed": { "type": "integer", "minimum": 0 },
          "tasks_total": { "type": "integer", "minimum": 0 },
          "errors": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "context_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selection_policy", "ordering_policy", "files_loaded", "docs_loaded"],
      "properties": {
        "selection_policy": { "type": "string", "minLength": 1 },
        "ordering_policy": { "type": "string", "minLength": 1 },
        "files_loaded": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "bytes"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "bytes": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "docs_loaded": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["url", "retrieved_at"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "retrieved_at": { "type": "string", "format": "date-time" }
            }
          }
        },
        "token_estimate": { "type": "integer", "minimum": 0 },
        "char_count_estimate": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
